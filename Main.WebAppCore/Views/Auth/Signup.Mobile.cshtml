@model AccountDisplayViewModel

@{
    ViewBag.Title = @Model.PageName;

   // Layout = "~/Views/Shared/_Layout.cshtml";
    Layout = "~/Views/Shared/_Layout.Mobile.cshtml";
    //Layout = "~/Views/Shared/_Layout.Tablet.cshtml";


    ViewBag.ExcludeHeader = false;
}

<div class="container">
        
            <div class="offset-1 col-10 card-form">

                <div class="row">
                    <div class="col-sm-12
                        col-xs-12
                        col-md-12
                        col-lg-12">
                        
                    <h4 class="card-title"> @SharedLocalizer["TitleRegisterPage"] </h4>

                    </div>
                </div>

                <div class="gap"></div>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-sm-12 
                                    col-xs-12 
                                    col-md-12 
                                    col-lg-12">

                            @Html.LabelFor( a => a.ClientName )

                            @Html.EditorFor(a => a.ClientName, new { htmlAttributes = new { @class = "fff"} })
                    
                            @Html.ValidationMessageFor( model => model.ClientName, "", 
                                    new { @class = "inline-field-error text-danger" } )
                
                        </div>
                    </div>
            

                    <div class="row">
                        <div class="col-sm-12  
                                    col-xs-12 
                                    col-md-12 
                                    col-lg-12">

                            @Html.LabelFor( a => a.Phone )

                            @Html.EditorFor(a => a.Phone, new { htmlAttributes = new { @class = "fff"} })

                            @Html.ValidationMessageFor(model => model.Phone, "", new { @class = "inline-field-error text-danger" })

                        </div>
                    </div>
            
                    <div class="row">
                        <div class="col-sm-12
                                    col-xs-12
                                    col-md-12
                                    col-lg-12">

                            @Html.LabelFor( a => a.Email )

                            @Html.EditorFor(a => a.Email, new { htmlAttributes = new { @class = "fff" } })

                            @Html.ValidationMessageFor(model => model.Email, "", new { @class = "inline-field-error text-danger" })

                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-12
                                    col-xs-12
                                    col-md-12
                                    col-lg-12">
               
                            @Html.LabelFor( a => a.Password )

                            @Html.PasswordFor(x => x.Password, new { id = "Password", @class = "fff" })

                            @Html.ValidationMessageFor(model => model.Password, "", new { @class = "inline-field-error text-danger" })

                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-12
                                    col-xs-12
                                    col-md-12
                                    col-lg-12">

                            @Html.LabelFor( a => a.RePassword )

                            @Html.PasswordFor(x => x.RePassword, new { id = "RePassword", @class = "fff" })

                            @Html.ValidationMessageFor(model => model.RePassword, "", new { @class = "inline-field-error text-danger" })

                        </div>
                    </div>

                    <div class="gap"></div>

                    <div class="row">
                        <div class="col-sm-12 
                                    col-xs-12 
                                    col-md-12 
                                    text-center">

                            <button class="primary-button
                                           flex max"
                                    type="submit">

                                @SharedLocalizer["ButtonTextRegister"]

                            </button>

                        </div>
                    </div>
                }
        </div>
    </div>
    
</div>


@section scriptsapp {

    @await Html.PartialAsync( "~/Views/Shared/_ValidationScriptsPartial.cshtml" )

    <script>

        PAGE_NAME = '@Model.PageName';

    </script>
}


