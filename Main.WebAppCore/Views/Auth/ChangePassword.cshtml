
@model ChangePasswordViewModel

@{
    ViewBag.Title = SharedLocalizer["PageNameChangePassword"];

    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewBag.ExcludeHeader = true;
}


<div class="container">

    <div class="offset-3 col-6 card-form">

    <div class="row">

        <div class="col-sm-12
            col-xs-12
            col-md-12
            col-lg-12">

            <h4 class="card-title all-caps"> 

                @SharedLocalizer["ChangePasswordTitle"]
               
            </h4>

        </div>

        <div class="gap"></div>

        <form id="formChangePassword" asp-action="ChangePassword" method="post">

            @Html.AntiForgeryToken( )
            @Html.HiddenFor( m => m.Email )

            <div class="col-sm-12
                col-xs-12
                col-md-12
                col-lg-12">

                    <label asp-for="CurrentPassword"></label>
                    <input asp-for="CurrentPassword" class="fff" type="password" />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            
            </div>

            <div class="col-sm-12
                col-xs-12
                col-md-12
                col-lg-12">

                    <label asp-for="NewPassword"></label>
                    <input asp-for="NewPassword" class="fff" type="password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
            
            </div>

            <div class="gap"></div>

            <div class ="col-sm-12
                        col-xs-12
                        col-md-12
                        col-lg-12">

                <button type="submit" class="primary-button flex max">
                    @SharedLocalizer["ChangePasswordButtonText"]
                </button>

            </div>
            
        </form>

    </div>

    </div>

</div>

@section scriptsapp {

    @await Html.PartialAsync( "~/Views/Shared/_ValidationScriptsPartial.cshtml" )

    <script>
        $(function() {
            $("#formChangePassword").valid();
        })
    </script>

}