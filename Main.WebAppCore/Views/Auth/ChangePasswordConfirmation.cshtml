@{
    ViewBag.Title = ViewData["Title"];
    
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewBag.ExcludeHeader = true;
}


<div class="container">

    <div class="offset-3 col-6 card-form">

        
        <div class="row">

            <div class="col-sm-12
                col-xs-12
                col-md-12
                col-lg-12">

                <h4 class="card-title all-caps"> @ViewData["Title"] </h4>
           
            </div>
        </div>

        <div class="gap"></div>
                        
        <div class="row">

            <div class="col-sm-12
                col-xs-12
                col-md-12
                col-lg-12">

                <p>
                    Your password has been successfully changed.
                    Please <a asp-action="Login" asp-controller="Auth">click here to log in</a>.
                </p>

            </div>

        </div>

    </div>

</div>
