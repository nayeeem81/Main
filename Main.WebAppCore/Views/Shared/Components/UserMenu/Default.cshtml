@inject IStringLocalizer<SharedResource> SharedLocalizer

@if ( User != null && User.Identity != null && User.Identity.IsAuthenticated )
{
    @if ( User.IsInRole ( "User" ) )
    {
        <div class="dropdown">
            <a class="dropdown-toggle text-truncate"
                data-toggle="dropdown"
                role="button"
                aria-haspopup="true"
                data-userid="@Model.UserID"
                data-bs-toggle="dropdown">
                <i class="fa fa-user fa-1x"></i>
                <span>@User.Identity.Name</span>
                <span class="caret"></span>
            </a>
                    
            <ul class="dropdown dropdown-menu" id="divMenuMyHomeSignin">

                <li class="dropdown-header">Account Setting</li>

                <li class="user-menu">

                    <a class="dropdown-item dropdown-item-text icon-button" 
                        asp-controller="Account" 
                        asp-action="Profile"
                        asp-area="">
                        
                        <i class="fa fa-user fa-fw"></i>
                        
                        <span>
                            @SharedLocalizer["ProfileLinkText"]
                        </span>

                    </a>

                </li>

                
                <li>
                    <a class="dropdown-item dropdown-item-text icon-button"
                       asp-area=""
                       asp-controller="Auth"
                       asp-action="ChangePassword">

                        <i class="fa fa-fw fa-edit"></i>

                        <span>
                            @SharedLocalizer["ChangePasswordLinkText"]
                        </span>

                    </a>
                </li>

                @await Html.PartialAsync( "~/Views/Shared/Components/_MainMenuCommonLinks.cshtml" )
                
            </ul>
        </div>
    }
}   