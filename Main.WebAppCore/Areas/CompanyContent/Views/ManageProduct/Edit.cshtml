@model ProductViewModel

@{
    ViewBag.Title = SharedLocalizer["ViewBagTitleEditPost"];
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.ExcludeHeader = true;
}

<div id="editAdminPostMainView" class="container">
    @await Html.PartialAsync("~/Areas/CompanyContent/Views/ManageProduct/_EditProduct.cshtml", Model)
</div>

@section scriptsapp {

    @await Html.PartialAsync("~/Views/Shared/_ValidationScriptsPartial.cshtml")


    <script>
        var notify = $.notify;

        PAGE_NAME = '@Model.PageName';

        var getSubCategoryURL = '@Url.Action("GetSubCategories", "ManageProduct")?id=';
        var uploadImageURL = '@Url.Action("UploadImage", "ManageProduct")';
        var loadImageURL = '@Url.Action( "LoadImage","ManageProduct" )';
        var removeImageShortContentURL = '@Url.Action("ImageRemove", "ManageProduct")?id=';

        var SUCCESS = "Success";
        var IMAGE_LOAD_SUCCESSFUL = "Image load successful!";

        
        function ResetSubCategory() {
            $("#SubCategoryID").val("");

            $("#spanCategoryDropdown").text("");

            $('#SubCategoryID').empty();

            return true;
        }


        function PopulateSubCategory(items) {

            $('#SubCategoryID').empty();

            $.each(items, function(i, item) {
                if (item.text != null) 
                {
                    $('#SubCategoryID').append(
                        "<option value='" + item.value + "'>" + item.text + "</option>"
                    );
                } 
                else 
                {
                    $('#SubCategoryID').append(
                        "<option value='" + item.value + "'>Select</option>"
                    );
                }
            });
        }


        function LoadImageEditAdminContent() {

            $.ajax({
                type: "GET",
                url: loadImageURL,
                cache: false,
                async: true,
                success: function (result) {

                    $("#imageEditPanelContainer").append(result);

                    notify({
                        type: 'success',
                        message: '<strong><i class="fa fa-thumbs-up"></i>&nbsp;' + SUCCESS + '</strong> ' + IMAGE_LOAD_SUCCESSFUL,
                        allow_dismiss: true,
                        placement: {
                            from: "top",
                            align: "right"
                        },
                        delay: { show: 10, hide: 10 },
                        template: '<div data-notify="container" class="col-xs-11 col-sm-3 alert alert-{0}" role="alert">' +
                        '<button type="button" aria-hidden="true" class="close" data-notify="dismiss">×</button>' +
                        '<span data-notify="icon"></span>' +
                        '<span data-notify="title">{1}</span>' +
                        '<span data-notify="message">{2}</span>' +
                        '</div>'
                    });
                },
                error: function (error) {
                   console.log(error);
                }
            });
        }


        $(document).ready(function () {

            $(document).on("change", "#CategoryID", function() {

                var category = $(this).val();

                if (ResetSubCategory()) {
                    $.ajax({
                        url: getSubCategoryURL + category,
                        type: 'GET',
                        dataType: 'json',
                        cache: true,
                        success: function(items) {
                            PopulateSubCategory(items);
                        },
                        error: function(error) {
                            console.log(error);
                        }
                    });
                }
            });

             
            var btnUploadSelector = $("#editAdminPostMainView").find("#btnUpload");

            btnUploadSelector.on("click", function () {
                
                var ERROR_MASSAGE = "Select a file!";

                var fileElement = $('#fileInput') [0];
                var files = fileElement.files;

                if (files.length === 0) {
                    return;
                }

                var formDataEdit = new FormData();
                
                formDataEdit.append("file", files[0]);

                $.ajax({
                    url: uploadImageURL, 
                    type: 'POST',
                    data: formDataEdit,
                    processData: false, 
                    contentType: false, 
                    success: function (response) {
                        LoadImageEditAdminContent();
                    },
                    error: function (error) {
                        console.log(error);
                    }
                });
            });


            document.getElementById("myMainFormEdit").addEventListener("submit", function (e) {
                
                e.preventDefault();
                
                const formData = new FormData(this);
    
                fetch(this.action, {
                    method: 'POST',
                    credentials: 'same-origin',
                    body: formData
                })
                .then(response => {
            
                    return response.json().then(data => {
              
                              console.log("Status Code:", response.status);
                              console.log("JSON Data:", data);
      
                              if (response.status === 200)
                              {
                                    window.location.href = data.urlGo;
                              }
                              else if (response.status === 400)
                              {
                                    return;
                              }
                              return;
                        });
                })
                .catch(error => {
                    console.error("Network or parsing error:", error);
                    return;
                });
            });
           

            $(document).on("click", ".btn-remove-image", function () {

                var that = this;
                var id = $(that).data("id");
                var postId = $(that).data("postid");
                var rem = $(that).closest(".image-content");

                $(rem).remove();

                $.ajax({
                    url: removeImageShortContentURL + id + "&postId=" + postId,
                    type: 'DELETE',
                    dataType: 'json',
                    processData: false,
                    cache: false,
                    async: true,
                    success: function (response) {
                        console.log(response);
                    },
                    error: function (error) {
                        console.log(error);
                    }
               });
            });

        });
    </script>
}