@model PanelViewModel

<div class="panel container"
     data-panel-position="@Model.PanelPosition"
     data-page-id="@Model.PageID"
     data-panel-id="@Model.PanelID"
     draggable="true">

    <h4 class="sub-title" draggable="false">
        @Model.PanelTitle
    </h4>

  
    <div class="row edit-post-parent panel-content" 
         data-panel-id = "@Model.PanelID"
         data-page-id = "@Model.PageID"
         draggable="false">

        @{
            foreach ( var product in Model.ListPosts.ToList())
            {
                <div 
                     class="col-md-3 col-sm-3 col-lg-3 col-xs-3 card edit-post-item"
                     data-postorder="@product.ImageOrderID"
                     data-panelpostid = "@product.PanelPostID"
                     data-imageid = "@product.ImageFileID"
                     data-postid = "@product.RootID"
                     draggable="true">
                           
                    <a class="thumbnail only-image" draggable="false">

                        @if ( product.ImageFileContent != null )
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image4X.cshtml", product.ImageFileContent )
                                
                        }
                        else
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image4X.cshtml", new byte[1] )
                                    
                        }

                    </a>


                    <div class="caption card-body"
                         draggable="false">

                        <h5 class="truncate text-bg-success card-title"
                            draggable="false">

                            @product.PostTitle

                        </h5>

                        <p class="fa-dollar text-info-emphasis card-text"
                           draggable="false">

                            @product.Price Taka

                        </p>

                        <span draggable="false">

                            <i class="fa fa-plus fa-fw"></i>

                            ADD TO CART

                        </span>

                    </div>
                
                </div>
            }
        }

    </div>

</div>