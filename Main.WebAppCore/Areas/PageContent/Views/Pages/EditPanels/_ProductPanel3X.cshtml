@model PanelViewModel

<div class="panel container"
     data-panel-position="@Model.PanelPosition"
     data-page-id="@Model.PageID"
     data-panel-id="@Model.PanelID"
     draggable="true">

    <h4 class="sub-title" draggable="false">
        @Model.PanelTitle
    </h4>
  
    <div class="row edit-post-parent panel-content" 
         data-panel-id = "@Model.PanelID"
         data-page-id = "@Model.PageID"
         draggable="false">

        @{
            foreach ( var product in Model.ListPosts.ToList())
            {
                <div 
                     class="col-md-4 col-sm-4 col-lg-4 col-xs-4 card edit-post-item" 
                     data-postorder="@product.ImageOrderID"
                     data-panelpostid = "@product.PanelPostID"
                     data-imageid = "@product.ImageFileID"
                     data-imageorder = "@product.ImageOrderID"
                     data-postid = "@product.RootID"
                     draggable="true">
                           
                    <a class="thumbnail only-image card-img-top" 
                       draggable="false">

                        @if ( product.ImageFileContent != null )
                        {
                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image3X.cshtml", product.ImageFileContent )  
                        }
                        else
                        {
                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image3X.cshtml", new byte[1] )  
                        }

                    </a>


                    <div class="card-body" 
                         style="margin-bottom:10px;" 
                         draggable="false">

                            <h5 class="truncate text-bg-success card-title" 
                                style="text-align:center;" 
                                draggable="false">

                                    @product.PostTitle

                            </h5>

                            <p class="fa-dollar text-info-emphasis card-text" 
                               style="text-align:center;"
                               draggable="false">

                                    @product.Price Taka

                            </p>

                        <span style="vertical-align:middle;text-align:center;" 
                              draggable="false">

                            <i class="fa fa-plus fa-fw"  
                               draggable="false">

                            </i>

                            ADD TO CART

                        </span>

                    </div>
                
                </div>
            }
        }

    </div>

</div>