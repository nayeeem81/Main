@model PanelViewModel

<div class="panel container"
     data-panel-position="@Model.PanelPosition"
     data-page-id="@Model.PageID" 
     data-panel-id="@Model.PanelID" 
     draggable="true">
   
    <div class="row panel-header">
        <div class="col-12">
            <h4 class="sub-title" draggable="false">
                @Model.PanelTitle
            </h4>
        </div>
    </div>

    <div class="row edit-post-parent panel-content" 
        data-panel-id = "@Model.PanelID"
        data-page-id = "@Model.PageID"
        draggable="false">

        @{
            foreach ( var product in Model.ListPosts.ToList())
            {
                <div class="col-md-6 col-sm-6 col-lg-6 col-xs-6 card edit-post-item" 
                     data-image-order-id="@product.ImageOrderID"
                     data-panel-post-id = "@product.PanelPostID"
                     data-image-file-id = "@product.ImageFileID"
                     data-image-order-id = "@product.ImageOrderID"
                     data-root-id = "@product.RootID"
                     draggable="true">
                           
                    <a class="thumbnail only-image" draggable="false">

                        @if ( product.ImageFileContent != null )
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image2X.cshtml", product.ImageFileContent )
                                
                        }
                        else
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image2X.cshtml", new byte[1] )
                                    
                        }

                    </a>


                    <div class="caption card-body" style="margin-bottom:10px;" draggable="false">

                        <h5 class="truncate text-bg-success card-title" style="text-align:center;" draggable="false">
                            @product.PostTitle
                        </h5>

                        <p class="fa-dollar text-info-emphasis card-text" style="text-align:center;" draggable="false">
                            @product.Price Taka
                        </p>

                        <span style="vertical-align:middle;" draggable="false">
                            <i class="fa fa-plus fa-fw"></i>ADD TO CART
                        </span>
                    </div>
                
                </div>
            }
        }

    </div>

</div>