@using Main.Common.Enums
@model List<PagePanelViewModel>

@section Styles {
    <link rel="stylesheet" href="~/css/dragdrop.css" />
}

@{
    ViewData["Title"] = "Edit Panels";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.ExcludeHeader = false;
}



<div class="container"> 

    <div class="gap"></div>

    <h4 class="card-title">EDIT PANELS</h4>

    <div class="gap"></div>
    <div class="gap"></div>

</div>

<div class="panel-list">

    @{
        foreach(var model in Model.ToList())
        {

            if ( model.PanelTemplate == EnumPanelTemplate.ProductSixer)
            {
                @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/EditPanels/_ProductPanel6X.cshtml",model )
            }
            else if ( model.PanelTemplate == EnumPanelTemplate.ProductQuard )
            {
                @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/EditPanels/_ProductPanel4X.cshtml",model )
            }
            else if ( model.PanelTemplate == EnumPanelTemplate.ProductTriangle )
            {
                @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/EditPanels/_ProductPanel3X.cshtml",model )
            }
            else if ( model.PanelTemplate == EnumPanelTemplate.ProductDouble )
            {
                @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/EditPanels/_ProductPanel2X.cshtml",model )
            }
        }
    }

</div>

@section scriptsapp {

    <script>

        (function () {

            const container = document.querySelector('.panel-list');
            let dragSrcEl = null;

            // 1. Drag Start: User picks up a panel
            container.addEventListener('dragstart', (e) => {
                  const targetPanel = e.target.closest('.panel');

                  if (!targetPanel) return;

                  dragSrcEl = targetPanel;

                  // Delay adding the class so the browser's native drag image doesn't look invisible
                  setTimeout(() => {
                    targetPanel.classList.add('is-dragging');
                  }, 0);

                  // Set drag effect allowed
                  e.dataTransfer.effectAllowed = 'move';
            });

            // 2. Drag Over: Fired continuously as an item is dragged over a valid target
            container.addEventListener('dragover', (e) => {
                  e.preventDefault(); // Required to allow dropping

                  const targetPanel = e.target.closest('.panel');
                  if (!targetPanel || targetPanel === dragSrcEl) return;

                  // Determine where to insert based on the mouse position relative to the target panel
                  const rect = targetPanel.getBoundingClientRect();
                  const next = (e.clientY - rect.top) / (rect.bottom - rect.top) > 0.5;

                  // Dynamically move the element in the DOM (simulates the placeholder reflow)
                  container.insertBefore(dragSrcEl, next ? targetPanel.nextSibling : targetPanel);
            });

            // 3. Drag End: User releases the item (anywhere)
            container.addEventListener('dragend', (e) => {
                  const targetPanel = e.target.closest('.panel');
                  if (!targetPanel) return;

                  // Clean up the styling classes
                  targetPanel.classList.remove('is-dragging');
                  dragSrcEl = null;

                  // Optional: Trigger a save function here
                  //saveNewOrder();
            });

            // 4. Save Layout Function
            function saveNewOrder() {
                  const panels = Array.from(container.querySelectorAll('.panel'));
                  const order = panels.map((panel, index) => {
                    return {
                      id: panel.dataset.id || index,
                      position: index
                    };
                  });
                  console.log('Saved layout order:', order);
                  // Send 'order' data to your backend API or localStorage
            }



        });

    </script>

}