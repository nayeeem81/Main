@model PanelViewModel

<div class="container">

    <h4 class="sub-title">

        @Model.PanelTitle

    </h4>

    <div class="row">

        @{
            foreach ( var product in Model.ListPosts.ToList())
            {
                <div class="col-md-3 col-sm-3 col-lg-3 col-xs-3 card">
                           
                    <a class="thumbnail only-image">

                        @if ( product.ImageFileContent != null )
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image4X.cshtml", product.ImageFileContent )
                                
                        }
                        else
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image4X.cshtml", new byte[1] )
                                    
                        }

                    </a>


                    <div class="caption card-body">

                        <h5 class="truncate text-bg-success card-title">
                            @product.PostTitle
                        </h5>

                        <p class="fa-dollar text-info-emphasis card-text">
                            @product.Price Taka
                        </p>

                        <span>
                            <i class="fa fa-plus fa-fw"></i>

                            ADD TO CART
                        </span>

                    </div>
                
                </div>
            }
        }

    </div>

</div>