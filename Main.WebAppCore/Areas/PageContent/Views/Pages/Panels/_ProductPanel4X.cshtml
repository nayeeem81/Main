@model PanelViewModel

<div class="container">

    <h4 class="sub-title">

        @Model.PanelTitle

    </h4>

    <div class="row">

        @{
            foreach ( var product in Model.ListPosts.ToList())
            {
                <div class="col-md-3 col-sm-3 col-lg-3 col-xs-3 card-form">
                           
                    <a class="thumbnail only-image">

                        @if ( product.ImageFileContent != null )
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image4X.cshtml", product.ImageFileContent )
                                
                        }
                        else
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image4X.cshtml", new byte[1] )
                                    
                        }

                    </a>


                    <div class="caption" style="margin-bottom:10px;">

                            <div class="truncate text-bg-success">

                                @product.PostTitle
                                    
                            </div>

                            <div class="fa-dollar text-info-emphasis">

                                @product.Price Taka
                                    
                            </div>
                                    
                            <div class="add-to-cart sub-content text-center" data-id="@product.RootID">
                                        
                                <button role="link" class="primary-button max"> ADD TO CART </button>

                            </div>
                                    
                            
                    </div>
                
                </div>
            }
        }

    </div>

</div>