@model PagePanelViewModel

@{
    string hide = "";

    List<PanelPostViewModel> list = new List<PanelPostViewModel>();

    if ( Model.ListPanelPosts == null || Model.ListPanelPosts.Count == 0)
    {
        hide = "hide";
    }
    else
    {
        if ( Model.ListPanelPosts.Count < 6)
        {
            hide = "hide";
        }
        else
        {
            list = Model.ListPanelPosts.Take<PanelPostViewModel> ( 6 ).ToList();
        }
    }
}

<div class="container @hide">
    
    <h4 class="sub-title">        
        @Model.PanelTitle
    </h4>

    <div class="row">

        @{
            foreach ( var product in list.ToList())
            {
                <div class="col-md-2 col-sm-2 col-lg-2 col-xs-2 card">
                           
                    <a class="thumbnail only-image card-img-top">

                        @if ( product.ImageFileContent != null )
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image6X.cshtml", product.ImageFileContent )
                                
                        }
                        else
                        {

                            @await Html.PartialAsync( "~/Areas/PageContent/Views/Pages/Images/_Image6X.cshtml", new byte[1] )
                                    
                        }

                    </a>


                    <div class="caption" style="margin-bottom:10px;">

                        <h5 class="truncate text-bg-success card-title" style="text-align:center;">
                            @product.PostTitle
                        </h5>

                        <p class="fa-dollar text-info-emphasis card-text" style="text-align:center;">
                            @product.Price Taka
                        </p>

                        <span style="vertical-align:middle;"><i class="fa fa-plus fa-fw"></i>ADD TO CART</span>
                        
                    </div>
                </div>
            }
        }

    </div>

</div>